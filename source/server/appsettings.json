{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "InstrumentationKey=00000000-0000-0000-0000-000000000000"
  },
  "AgentApplication": {
    "UserAuthorization": {
      "AutoSignIn": true,
      "DefaultHandlerName": "Copilot",
      "Handlers": {
        "Copilot": {
          "Settings": {
            "AzureBotOAuthConnectionName": "OAuth2",
            "OBOConnectionName": "CopilotConnection"
          }
        }
      }
    }
  },
  "Connections": {
    "CopilotConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "ClientId": "{{MICROSOFT_365_COPILOT_ID}}",
        "ClientSecret": "{{MICROSOFT_365_COPILOT_PASSWORD}}",
        "TenantId": "{{MICROSOFT_365_COPILOT_TENANT_ID}}"
      }
    },
    "ServiceConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "ClientId": "{{MICROSOFT_365_AGENT_ID}}",
        "ClientSecret": "{{MICROSOFT_365_AGENT_PASSWORD}}",
        "TenantId": "{{MICROSOFT_365_AGENT_TENANT_ID}}",
        "Scopes": [
          "https://api.botframework.com/.default"
        ]
      }
    }
  },
  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "ServiceConnection"
    }
  ],
  "TokenValidation": {
    "Audiences": [
      "{{MICROSOFT_365_AGENT_ID}}"
    ],
    "TenantId": "{{MICROSOFT_365_AGENT_TENANT_ID}}"
  }
}
